<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title><%= title %></title>
    <link rel="stylesheet" href="/stylesheets/style.css" />
</head>
<body class="show">

<nav>
    <ul>
        <li><a href="/">Home</a></li>
        <li><a href="/book">Books</a></li>
        <li><a href="/book/create">Create book</a></li>
    </ul>
</nav>

<main>
    <h1><%= book.title %></h1>
    <h3><%= book.author %></h3>

    <article>
        <%= book.description %>
    </article>

    <ul class="action-list">
        <li><a href="/book">Back to list</a></li>
        <li><a href="/book/<%= book.id %>/edit">Edit</a></li>
    </ul>
</main>
</body>
</html>