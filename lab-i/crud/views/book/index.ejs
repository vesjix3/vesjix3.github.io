<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title><%= title %></title>
    <link rel="stylesheet" href="/stylesheets/style.css" />
</head>
<body class="index">

<nav>
    <ul>
        <li><a href="/">Home</a></li>
        <li><a href="/book">Books</a></li>
        <li><a href="/book/create">Create book</a></li>
    </ul>
</nav>

<main>
    <h1>Books List</h1>

    <a href="/book/create">Create new</a>

    <ul class="index-list">
        <% books.forEach(function(book) { %>
        <li>
            <h3><%= book.title %></h3>
            <p><%= book.author %></p>
            <ul class="action-list">
                <li><a href="/book/<%= book.id %>">Details</a></li>
                <li><a href="/book/<%= book.id %>/edit">Edit</a></li>
            </ul>
        </li>
        <% }) %>
    </ul>
</main>
</body>
</html>